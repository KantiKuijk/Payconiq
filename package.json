{
  "name": "payconiq",
  "version": "0.4.2",
  "description": "Node.js implementation for interacting with the Payconiq V3 API",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "npm run build;NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs",
    "build": "tsc",
    "format": "prettier --write \"**/*.ts\" \"**/*.js\"",
    "lint": "tslint -p tsconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run lint",
    "preversion": "npm run lint",
    "version": "npm run format && git add -A",
    "postversion": "git push && git push --tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KantiKuijk/Payconiq.git"
  },
  "keywords": [
    "bancontact",
    "bancontactpro",
    "wero",
    "epi",
    "payment",
    "onlinepayment",
    "mobilepayment",
    "api"
  ],
  "author": "Kanti Kuijk",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/KantiKuijk/Payconiq/issues"
  },
  "homepage": "https://github.com/KantiKuijk/Payconiq#readme",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.5",
    "jest": "^30.2.0",
    "prettier": "^3.7.4",
    "ts-jest": "^29.4.6",
    "tslint": "^6.1.3",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "index.ts",
    "index.d.ts"
  ]
}